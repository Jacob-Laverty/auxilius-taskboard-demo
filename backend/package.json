{
  "name": "auxilius-taskboard-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc -p tsconfig.migrations.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node-pg-migrate -j ts -m migrations",
    "migrate:up": "node-pg-migrate up -j ts -m migrations",
    "migrate:down": "node-pg-migrate down -j ts -m migrations",
    "migrate:up:js": "node-pg-migrate up -j js -m dist/migrations",
    "migrate:down:js": "node-pg-migrate down -j js -m dist/migrations"
  },
  "keywords": [],
  "author": "Jacob Laverty",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
